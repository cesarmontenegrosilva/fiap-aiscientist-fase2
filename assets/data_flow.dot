digraph G {
  graph [rankdir=TB, bgcolor="white", pad=0.3, nodesep=0.3, ranksep=0.45, fontname="Arial"];
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, color="#24445C", fillcolor="#F5F8FA"];
  edge [color="#53758C", penwidth=1.3, arrowsize=0.7, fontname="Arial", fontsize=9];
  a [label="1. Terraform cria APIs, IAM, datasets, bucket, tópico e tabelas", fillcolor="#E8F3FF"];
  b [label="2. Cloud Run executa batch, grava Bronze/Parquet e aciona Dataform", fillcolor="#EAD6C5"];
  c [label="3. Simulador publica JSON no Pub/Sub", fillcolor="#FFF4D9"];
  d [label="4. Dataflow valida esquema, faixa, UF, chave e data", fillcolor="#FFF4D9"];
  e [label="5. Eventos válidos → Bronze | inválidos → dead-letter", fillcolor="#EAD6C5"];
  f [label="6. Dataform transforma Bronze → Silver", fillcolor="#E3E8ED"];
  g [label="7. Assertions e script de qualidade bloqueiam inconsistências", fillcolor="#FBE7EA"];
  h [label="8. Dataform publica Gold: metas, rankings, séries e features ML", fillcolor="#F4D78B"];
  i [label="9. Looker Studio / BigQuery ML / Vertex AI", fillcolor="#E1F4E8"];
  a -> b -> f;
  a -> c -> d -> e -> f;
  f -> g -> h -> i;
}
