# 1) TROQUE SEU_PROJECT_ID pelo ID real do projeto criado para o evento.
GCP_PROJECT_ID=SEU_PROJECT_ID

# 2) Região usada por Dataflow, Cloud Run e Scheduler.
GCP_REGION=us-central1

# 3) Mantenha US para compatibilidade com as tabelas públicas usadas.
BIGQUERY_LOCATION=US

# 4) TROQUE também o bucket; o nome precisa ser globalmente único.
GCS_BUCKET=SEU_PROJECT_ID-alfabetizacao-lake

# Datasets da arquitetura medalhão.
BQ_DATASET_BRONZE=alfabetizacao_bronze
BQ_DATASET_SILVER=alfabetizacao_silver
BQ_DATASET_GOLD=alfabetizacao_gold
BQ_DATASET_MONITORING=alfabetizacao_monitoring
BQ_DATASET_ASSERTIONS=alfabetizacao_assertions

# Recursos do streaming simulado.
PUBSUB_TOPIC=alfabetizacao-indicadores
PUBSUB_SUBSCRIPTION=alfabetizacao-indicadores-dataflow

# Fonte pública; NÃO troque pelo seu project ID.
SOURCE_PROJECT=basedosdados
SOURCE_DATASET=br_inep_avaliacao_alfabetizacao

# Pastas temporárias do Dataflow; troque SEU_PROJECT_ID.
TEMP_LOCATION=gs://SEU_PROJECT_ID-alfabetizacao-lake/tmp
STAGING_LOCATION=gs://SEU_PROJECT_ID-alfabetizacao-lake/staging
DATAFLOW_SERVICE_ACCOUNT=alfabetizacao-dataflow@SEU_PROJECT_ID.iam.gserviceaccount.com

# Teto de 10 GiB por consulta para impedir leituras inesperadamente grandes.
MAXIMUM_BYTES_BILLED=10737418240
